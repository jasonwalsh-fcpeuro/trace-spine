{:paths ["src" "resources"]

 :deps
 {;; Core Clojure
  org.clojure/clojure {:mvn/version "1.12.0"}
  org.clojure/core.async {:mvn/version "1.6.681"}
  org.clojure/tools.logging {:mvn/version "1.3.0"}

  ;; Ring HTTP Server
  ring/ring-core {:mvn/version "1.12.2"}
  ring/ring-jetty-adapter {:mvn/version "1.12.2"}
  ring/ring-json {:mvn/version "0.5.1"}
  ring/ring-defaults {:mvn/version "0.5.0"}

  ;; Reitit Router
  metosin/reitit {:mvn/version "0.7.2"}
  metosin/reitit-ring {:mvn/version "0.7.2"}
  metosin/reitit-spec {:mvn/version "0.7.2"}
  metosin/reitit-swagger {:mvn/version "0.7.2"}
  metosin/reitit-swagger-ui {:mvn/version "0.7.2"}

  ;; GraphQL - Lacinia
  com.walmartlabs/lacinia {:mvn/version "1.2.2"}
  com.walmartlabs/lacinia-pedestal {:mvn/version "1.2"}

  ;; Authentication - Buddy
  buddy/buddy-auth {:mvn/version "3.0.323"}
  buddy/buddy-sign {:mvn/version "3.5.351"}
  buddy/buddy-hashers {:mvn/version "2.0.167"}
  buddy/buddy-core {:mvn/version "1.12.0-430"}

  ;; trace-spine middleware (local path for development)
  ;; In production, use coordinates like:
  ;; com.petstore/trace-spine {:mvn/version "0.1.0"}
  trace-spine/trace-spine {:local/root "../../lib/clj"}

  ;; HTTP Client for downstream calls
  clj-http/clj-http {:mvn/version "3.13.0"}

  ;; Redis for rate limiting and sessions
  com.taoensso/carmine {:mvn/version "3.4.1"}

  ;; JSON handling
  metosin/jsonista {:mvn/version "0.3.10"}
  cheshire/cheshire {:mvn/version "5.13.0"}

  ;; Configuration
  aero/aero {:mvn/version "1.1.6"}

  ;; Logging
  ch.qos.logback/logback-classic {:mvn/version "1.5.6"}
  org.slf4j/slf4j-api {:mvn/version "2.0.13"}

  ;; Metrics and Tracing
  io.opentelemetry/opentelemetry-api {:mvn/version "1.38.0"}
  io.opentelemetry/opentelemetry-sdk {:mvn/version "1.38.0"}

  ;; Spec for validation
  org.clojure/spec.alpha {:mvn/version "0.5.238"}
  metosin/spec-tools {:mvn/version "0.10.7"}

  ;; UUID generation
  clj-ulid/clj-ulid {:mvn/version "1.0.0"}

  ;; Environment
  environ/environ {:mvn/version "1.2.0"}}

 :aliases
 {:dev
  {:extra-paths ["dev" "test"]
   :extra-deps
   {nrepl/nrepl {:mvn/version "1.1.2"}
    cider/cider-nrepl {:mvn/version "0.49.2"}
    ring/ring-mock {:mvn/version "0.4.0"}
    lambdaisland/kaocha {:mvn/version "1.91.1392"}}}

  :test
  {:extra-paths ["test"]
   :extra-deps
   {lambdaisland/kaocha {:mvn/version "1.91.1392"}
    ring/ring-mock {:mvn/version "0.4.0"}
    nubank/matcher-combinators {:mvn/version "3.9.1"}}
   :main-opts ["-m" "kaocha.runner"]}

  :run
  {:main-opts ["-m" "api.core"]}

  :uberjar
  {:extra-deps
   {uberdeps/uberdeps {:mvn/version "1.3.0"}}
   :main-opts ["-m" "uberdeps.uberjar"
               "--main-class" "api.core"
               "--target" "target/api.jar"]}

  :docs
  {:extra-paths ["docs"]
   :extra-deps
   {codox/codox {:mvn/version "0.10.8"}}
   :main-opts ["-m" "codox.main"]}

  :repl
  {:main-opts ["-m" "nrepl.cmdline"
               "--middleware" "[cider.nrepl/cider-middleware]"]}}}
