{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aygp-dr/trace-spine/schema/notes/conjecture.schema.json",
  "title": "CPRR Conjecture Note",
  "description": "Git note recording a conjecture about system behavior",
  "type": "object",
  "required": ["schema", "trace_id", "commit", "timestamp", "conjecture"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "cprr-conjecture/v1"
    },
    "trace_id": {
      "type": "string",
      "pattern": "^[0-9A-Z]{26}$",
      "description": "ULID from work session"
    },
    "commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{7,40}$",
      "description": "Git commit SHA"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp"
    },
    "conjecture": {
      "type": "object",
      "required": ["id", "statement", "refutation_condition"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^C-(local-)?[0-9]+$",
          "description": "Local or global conjecture ID"
        },
        "statement": {
          "type": "string",
          "minLength": 10,
          "description": "The conjecture statement"
        },
        "cprr_ref": {
          "type": "string",
          "pattern": "^C-[0-9]+$",
          "description": "Reference to spec/cprr.org row if applicable"
        },
        "evidence_required": {
          "type": "string",
          "description": "What evidence would support this conjecture"
        },
        "refutation_condition": {
          "type": "string",
          "description": "What would falsify this conjecture"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
